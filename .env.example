# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/intellilearn
# Or for MySQL: mysql+pymysql://username:password@localhost:3306/intellilearn

# LLM API Keys (Choose one or multiple)
OPENAI_API_KEY=your_openai_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# LLM Configuration
LLM_PROVIDER=mistral  # Options: openai, mistral, local
LLM_MODEL=mistral-medium  # For Mistral or gpt-4 for OpenAI
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Vector Store Configuration
VECTOR_STORE_PATH=./data/vector_store
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Application Settings
APP_NAME=IntelliLearn AI
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your_secret_key_here

# Model Paths
SKILL_GAP_MODEL_PATH=./models/skill_gap_model.pkl
RECOMMENDER_MODEL_PATH=./models/recommender_model.pkl

# Analytics Configuration
ANALYTICS_RETENTION_DAYS=365
ROI_CALCULATION_INTERVAL=30
